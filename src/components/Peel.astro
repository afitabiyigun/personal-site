---
/*
  Reusable layered drag-reveal.
  Usage:
    <Peel corner="tr">
      <Fragment slot="top">...front shape / image...</Fragment>
      <Fragment slot="back">...revealed content...</Fragment>
    </Peel>

  The corner's grab handle is a real <button> for keyboard + screen-reader access.
*/

interface Props {
  corner?: 'tl' | 'tr' | 'bl' | 'br';
  label?: string;
  rounded?: boolean;
  aspect?: string; /* e.g. '4 / 3' */
}
const { corner = 'tr', label = 'Peel to reveal', rounded = true, aspect } = Astro.props;
const id = `peel-${Math.random().toString(36).slice(2, 9)}`;
---

<div
  class:list={['peel', `peel--${corner}`, { 'peel--round': rounded }]}
  data-peel
  data-peel-corner={corner}
  data-peel-state="closed"
  style={aspect ? `--peel-aspect:${aspect}` : undefined}
>
  <div class="peel-back" id={id}>
    <slot name="back" />
  </div>
  <div class="peel-top">
    <slot name="top" />
  </div>
  <div class="peel-flap" aria-hidden="true"></div>
  <button
    type="button"
    class="peel-handle"
    aria-label={label}
    aria-expanded="false"
    aria-controls={id}
  >
    <span class="peel-pinch" aria-hidden="true"></span>
  </button>
</div>

<style>
  .peel {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: var(--peel-aspect, 4 / 3);
    isolation: isolate;
    touch-action: none;
  }
  .peel--round { border-radius: var(--radius); overflow: visible; }

  .peel-back,
  .peel-top,
  .peel-flap {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    overflow: hidden;
  }

  .peel-back {
    background: var(--bg-soft);
    color: var(--ink);
    display: grid;
    place-items: center;
    padding: clamp(1rem, 3vw, 2rem);
    text-align: center;
    box-shadow: inset 0 0 0 1px var(--rule);
  }

  .peel-top {
    background: var(--bg-soft);
    z-index: 2;
    box-shadow: var(--shadow);
    clip-path: polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%);
    transition: box-shadow 200ms ease;
    display: grid;
    place-items: center;
    padding: clamp(0.6rem, 2vw, 1.2rem);
  }

  .peel-flap {
    z-index: 3;
    opacity: 0;
    background: linear-gradient(135deg, var(--bg) 0%, var(--bg-soft) 50%, var(--muted) 100%);
    filter: drop-shadow(0 4px 10px rgba(0,0,0,0.15));
    clip-path: polygon(0 0, 0 0, 0 0);
    pointer-events: none;
  }

  .peel[data-peel-state='closed'] .peel-top { cursor: grab; }
  .peel[data-peel-state='peeling'] .peel-top { cursor: grabbing; }

  .peel-handle {
    position: absolute;
    width: 42px;
    height: 42px;
    z-index: 5;
    padding: 0;
    background: transparent;
    border: 0;
    cursor: grab;
    border-radius: 50%;
  }
  .peel--tl .peel-handle { top: -6px; left: -6px; }
  .peel--tr .peel-handle { top: -6px; right: -6px; }
  .peel--bl .peel-handle { bottom: -6px; left: -6px; }
  .peel--br .peel-handle { bottom: -6px; right: -6px; }

  .peel-pinch {
    position: absolute;
    inset: 10px;
    border-radius: 50%;
    background: var(--ink);
    opacity: 0;
    transform: scale(0.6);
    transition: opacity 200ms ease, transform 200ms ease;
    box-shadow: 0 0 0 2px var(--bg);
  }
  .peel:hover .peel-pinch,
  .peel-handle:focus-visible .peel-pinch {
    opacity: 0.8;
    transform: scale(1);
  }
  .peel-handle:focus-visible {
    outline: 2px solid var(--accent-1);
    outline-offset: 4px;
  }

  /* Under reduced motion, make the handle look like a normal toggle. */
  @media (prefers-reduced-motion: reduce) {
    .peel-handle { cursor: pointer; }
    .peel-pinch { opacity: 0.8 !important; transform: scale(1) !important; }
  }
</style>

<script>
  import '../scripts/peel.ts';
</script>
