---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<Base title="writing · afit">
  <div class="container">
    <Nav />
    <header class="head">
      <p class="eyebrow mono">§ 03 · writing</p>
      <h1>Essays, notes, projects.</h1>
      <p class="lede">Selecting any text opens a floating link-to-selection icon. For the people who share paragraphs, not articles.</p>
    </header>

    <ul class="list">
      {posts.map((p) => (
        <li>
          <a href={`${base}/writing/${p.slug}`}>
            <span class="mono dim date">{fmt(p.data.date)}</span>
            <span class="title">{p.data.title}</span>
            {p.data.summary && <span class="summary">{p.data.summary}</span>}
            <span class="tags mono dim">
              {p.data.tags.map((t: string) => <span class="tag">#{t}</span>)}
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</Base>

<style>
  .head { padding: 3rem 0 2rem; }
  .eyebrow { color: var(--muted); font-size: 0.85rem; letter-spacing: 0.05em; text-transform: lowercase; margin: 0 0 1rem; }
  .lede { font-size: 1.1rem; color: var(--ink-soft); max-width: 62ch; }

  .list { list-style: none; padding: 0; margin: 0 0 4rem; }
  .list li { border-top: 1px solid var(--rule); }
  .list li:last-child { border-bottom: 1px solid var(--rule); }
  .list a {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 0.3rem 2rem;
    padding: 1.4rem 0.4rem;
    color: var(--ink);
    background-image: none;
    transition: background 200ms ease, padding 200ms ease;
  }
  .list a:hover { background: var(--bg-soft); padding-left: 1rem; }
  .date { grid-row: 1; grid-column: 1; align-self: baseline; }
  .title { grid-row: 1; grid-column: 2; font-size: 1.2rem; font-family: var(--font-display); font-weight: var(--display-weight); }
  .summary { grid-row: 2; grid-column: 2; color: var(--ink-soft); font-size: 0.95rem; }
  .tags { grid-row: 3; grid-column: 2; display: flex; gap: 0.6rem; font-size: 0.78rem; margin-top: 0.2rem; }
  .tag { color: var(--accent-1); }
  @media (max-width: 600px) {
    .list a { grid-template-columns: 1fr; }
    .date, .title, .summary, .tags { grid-column: 1; }
  }
</style>
