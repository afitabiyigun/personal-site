---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import ThemeSwitcher from '../components/ThemeSwitcher.astro';
import Unfold from '../components/Unfold.astro';
import FunkyShape from '../components/FunkyShape.astro';
---

<Base title="Afitab Iyigun — creative + curious">
  <div class="container">
    <Nav />

    <header class="hero">
      <div class="hero-copy">
        <p class="eyebrow mono">personal site · work in progress</p>
        <h1>
          hi, i'm <span class="accent">Afitab</span>.<br />
          i think about <em>minds</em>, <em>models</em>,<br />
          and <em>making things</em>.
        </h1>
        <p class="lede">
          Background in CS, math, and psychology. Currently working on AI
          safety. This site is for the rest — photos, video, half-baked notes,
          and whatever I'm playing with this week.
        </p>

        <div class="switcher-row">
          <span class="mono dim">paint the room:</span>
          <ThemeSwitcher />
        </div>
      </div>

      <aside class="hero-shapes" aria-label="Grab any corner of a shape and drag to unfold it">
        <figure class="shape-cell s1">
          <Unfold label="orange blob" minW={120} minH={120} startW={180} startH={180} maxW={520} maxH={520}>
            <FunkyShape variant={1} fill="var(--shape-1)" rotate={-6} />
          </Unfold>
          <figcaption>
            <strong>cs + math</strong>
            <span class="mono dim">algorithms, probability, linear algebra, category theory.</span>
          </figcaption>
        </figure>

        <figure class="shape-cell s2">
          <Unfold label="green blob" minW={120} minH={120} startW={180} startH={180} maxW={520} maxH={520}>
            <FunkyShape variant={3} fill="var(--shape-2)" rotate={8} />
          </Unfold>
          <figcaption>
            <strong>psychology</strong>
            <span class="mono dim">cognition, perception, belief under uncertainty.</span>
          </figcaption>
        </figure>

        <figure class="shape-cell s3">
          <Unfold label="peach blob" minW={120} minH={120} startW={180} startH={180} maxW={520} maxH={520}>
            <FunkyShape variant={2} fill="var(--shape-3)" rotate={-12} />
          </Unfold>
          <figcaption>
            <strong>ai safety</strong>
            <span class="mono dim">alignment, interpretability, legible systems.</span>
          </figcaption>
        </figure>

        <figure class="shape-cell s4">
          <Unfold label="blue blob" minW={120} minH={120} startW={180} startH={180} maxW={520} maxH={520}>
            <FunkyShape variant={5} fill="var(--shape-4)" rotate={4} />
          </Unfold>
          <figcaption>
            <strong>making things</strong>
            <span class="mono dim">photos, video, small tools, too-long essays.</span>
          </figcaption>
        </figure>
      </aside>
    </header>

    <section class="teasers">
      <a class="teaser mono" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/hobbies`}>
        <span class="num">01</span> hobbies → <span class="dim">looping videos of what i do offline</span>
      </a>
      <a class="teaser mono" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/photography`}>
        <span class="num">02</span> photography → <span class="dim">a running journal of things I noticed</span>
      </a>
      <a class="teaser mono" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/writing`}>
        <span class="num">03</span> writing → <span class="dim">essays, notes, projects</span>
      </a>
      <a class="teaser mono" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/garden`}>
        <span class="num">04</span> garden → <span class="dim">half-baked notes, safety + psych</span>
      </a>
    </section>

    <footer class="foot">
      <span class="mono dim">
        afitab iyigun · repainted <span data-repaint-count>0</span> times ·
        <a href="https://github.com/afitabiyigun">github</a> ·
        <span class="hint">(grab any corner of a shape and pull — it expands as much as you drag)</span>
      </span>
    </footer>
  </div>
</Base>

<style>
  .hero {
    padding: 3rem 0 5rem;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  @media (max-width: 840px) {
    .hero { grid-template-columns: 1fr; gap: 3rem; }
  }
  .eyebrow {
    color: var(--muted);
    margin: 0 0 1.2rem;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    text-transform: lowercase;
  }
  h1 { max-width: 22ch; }
  .accent { color: var(--accent-1); }
  em { font-style: italic; color: var(--accent-2); }
  .lede { font-size: 1.15rem; margin-top: 1.4rem; }
  .switcher-row {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-top: 2.6rem;
    flex-wrap: wrap;
  }
  .dim { color: var(--muted); font-size: 0.85rem; }
  .hint { opacity: 0.7; }

  .hero-shapes {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 28px 24px;
    align-items: start;
    justify-items: center;
  }
  .shape-cell {
    margin: 0;
    display: grid;
    gap: 10px;
    justify-items: center;
    text-align: center;
  }
  .shape-cell figcaption {
    display: grid;
    gap: 2px;
    max-width: 26ch;
    font-size: 0.92rem;
    color: var(--ink);
  }
  .shape-cell figcaption strong {
    font-family: var(--font-display);
    font-weight: var(--display-weight);
    letter-spacing: var(--letter-display);
  }

  .teasers {
    display: grid;
    gap: 1px;
    background: var(--rule);
    margin: 3rem 0 4rem;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .teaser {
    padding: 1rem 0;
    background: var(--bg);
    color: var(--ink);
    font-size: 1rem;
    background-image: none;
    display: flex;
    gap: 1rem;
    align-items: baseline;
    transition: padding 200ms ease, background 200ms ease;
  }
  .teaser:hover { padding-left: 0.8rem; background: var(--bg-soft); background-image: none; }
  .num { color: var(--accent-1); font-weight: 600; }
  .foot {
    padding: 3rem 0 2rem;
    border-top: 1px solid var(--rule);
    opacity: 0.9;
  }
</style>

<script>
  // Mirror the palette-switch counter into the footer.
  const el = document.querySelector<HTMLElement>('[data-repaint-count]');
  if (el) {
    try {
      const n = Number(localStorage.getItem('afit-palette-switches') || '0');
      el.textContent = String(n);
    } catch (_) {}
    document.addEventListener('afit:repaint', (e) => {
      const detail = (e as CustomEvent).detail as { count: number };
      el.textContent = String(detail.count);
    });
  }
</script>
