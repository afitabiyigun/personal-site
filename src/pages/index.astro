---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import ThemeSwitcher from '../components/ThemeSwitcher.astro';
import BlobMask from '../components/BlobMask.astro';
---

<Base title="Afitab Iyigun — creative + curious">
  {/*
    HERO — full above-the-fold.
      • white background
      • middle layer: nav + bio (normal flow inside .container)
      • top layer: the BlobMask overlay, which sits absolutely over the
        hero and clips its colorful artwork to a draggable blob shape.
        Only the blob itself receives pointer events, so the bio copy
        outside the blob is still selectable/interactive.
  */}
  <section class="hero-section" aria-label="Interactive blob — drag any point on the blob to reshape it">
    <div class="container hero-inner">
      <Nav />

      <header class="hero">
        <div class="hero-copy">
          <h1>
            hi, i'm <span class="accent">Afitab</span>.<br />
            i think about <em>minds</em>, <em>models</em>,<br />
            and <em>making things</em>.
          </h1>
          <p class="lede">
            Background in CS, math, and psychology. Currently working on AI
            safety. This site is for the rest — photos, video, half-baked notes,
            and whatever I'm playing with this week.
          </p>

          <div class="switcher-row">
            <span class="mono dim">paint the room:</span>
            <ThemeSwitcher />
          </div>
        </div>
      </header>
    </div>

    <BlobMask />

    <p class="blob-hint mono" aria-hidden="true">grab the blob — drag any point →</p>
  </section>

  <div class="container">
    <section class="teasers">
      <a class="teaser mono" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/hobbies`}>
        <span class="num">01</span> hobbies → <span class="dim">looping videos of what i do offline</span>
      </a>
      <a class="teaser mono" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/photography`}>
        <span class="num">02</span> photography → <span class="dim">a running journal of things I noticed</span>
      </a>
      <a class="teaser mono" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/garden`}>
        <span class="num">03</span> garden → <span class="dim">half-baked notes, safety + psych</span>
      </a>
      <a class="teaser mono" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/resume`}>
        <span class="num">04</span> resume → <span class="dim">CV, projects, research</span>
      </a>
    </section>

    <footer class="foot">
      <span class="mono dim">
        Afitab Iyigun · repainted <span data-repaint-count>0</span> times ·
        <a href="https://github.com/afitabiyigun">github</a> ·
        <span class="hint">(grab any point on the blob and drag to reshape it)</span>
      </span>
    </footer>
  </div>
</Base>

<style>
  /* ===== Hero: full-viewport, white bg, blob overlay on top ===== */
  .hero-section {
    position: relative;
    min-height: 100vh;
    background: #ffffff;
    overflow: hidden;
    isolation: isolate;
  }
  .hero-inner {
    position: relative;
    z-index: 1; /* middle layer — under the blob (z:10) */
  }

  .blob-hint {
    position: absolute;
    right: 1.2rem;
    bottom: 1rem;
    z-index: 2;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    color: #999;
    pointer-events: none;
    text-transform: lowercase;
  }

  .hero {
    padding: 2rem 0 4rem;
    max-width: 62ch;
  }
  .eyebrow {
    color: var(--muted);
    margin: 0 0 1.2rem;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    text-transform: lowercase;
  }
  h1 { max-width: 22ch; }
  .accent { color: var(--accent-1); }
  em { font-style: italic; color: var(--accent-2); }
  .lede { font-size: 1.15rem; margin-top: 1.4rem; }
  .switcher-row {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-top: 2.6rem;
    flex-wrap: wrap;
  }
  .dim { color: var(--muted); font-size: 0.85rem; }
  .hint { opacity: 0.7; }

  .teasers {
    display: grid;
    gap: 1px;
    background: var(--rule);
    margin: 3rem 0 4rem;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .teaser {
    padding: 1rem 0;
    background: var(--bg);
    color: var(--ink);
    font-size: 1rem;
    background-image: none;
    display: flex;
    gap: 1rem;
    align-items: baseline;
    transition: padding 200ms ease, background 200ms ease;
  }
  .teaser:hover { padding-left: 0.8rem; background: var(--bg-soft); background-image: none; }
  .num { color: var(--accent-1); font-weight: 600; }
  .foot {
    padding: 3rem 0 2rem;
    border-top: 1px solid var(--rule);
    opacity: 0.9;
  }
</style>

<script>
  // Mirror the palette-switch counter into the footer.
  const el = document.querySelector<HTMLElement>('[data-repaint-count]');
  if (el) {
    try {
      const n = Number(localStorage.getItem('afit-palette-switches') || '0');
      el.textContent = String(n);
    } catch (_) {}
    document.addEventListener('afit:repaint', (e) => {
      const detail = (e as CustomEvent).detail as { count: number };
      el.textContent = String(detail.count);
    });
  }
</script>
