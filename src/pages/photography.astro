---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const entries = (await getCollection('photography')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

/*
  Collage layout — each tile picks a pseudo-random size class based on its
  index so the grid reads as a hand-arranged mood board, not a uniform
  gallery. The sizes are stable (deterministic from index) so the layout
  doesn't jump between builds.
*/
const sizeCycle = ['tall', 'wide', 'small', 'square', 'tall', 'small', 'wide', 'square', 'small'] as const;
---

<Base title="photography · Afitab Iyigun">
  <div class="container">
    <Nav />
    <header class="head">
      <p class="eyebrow mono">§ 02 · photography</p>
      <h1>A journal of things I noticed.</h1>
      <p class="lede">Hover a photo — it dims, and the caption + metadata slides in from the bottom-right.</p>
    </header>

    <section class="collage">
      {entries.map((e, i) => (
        <figure class={`tile tile--${sizeCycle[i % sizeCycle.length]}`}>
          <Image
            src={e.data.photo}
            alt={e.data.caption}
            widths={[480, 960, 1440]}
            sizes="(min-width: 900px) 40vw, 100vw"
          />
          <figcaption class="overlay" aria-hidden="true">
            <div class="overlay-inner mono">
              <div class="title">{e.data.title}</div>
              <div class="caption">{e.data.caption}</div>
              <div class="meta">
                <span>{fmt(e.data.date)}</span>
                <span>· {e.data.location}</span>
              </div>
              {e.data.exif && (
                <div class="exif">
                  {e.data.exif.camera && <span>{e.data.exif.camera}</span>}
                  {e.data.exif.lens && <span>· {e.data.exif.lens}</span>}
                  {e.data.exif.shutter && <span>· {e.data.exif.shutter}</span>}
                  {e.data.exif.aperture && <span>· {e.data.exif.aperture}</span>}
                  {e.data.exif.iso && <span>· ISO {e.data.exif.iso}</span>}
                </div>
              )}
            </div>
          </figcaption>
        </figure>
      ))}
    </section>
  </div>
</Base>

<style>
  .head { padding: 3rem 0 2rem; }
  .eyebrow { color: var(--muted); font-size: 0.85rem; letter-spacing: 0.05em; text-transform: lowercase; margin: 0 0 1rem; }
  .lede { font-size: 1.1rem; color: var(--ink-soft); max-width: 62ch; }

  /*
    Collage grid. `grid-auto-flow: dense` lets CSS pack tiles of mixed
    sizes into holes, producing a masonry-like mosaic without JS.
  */
  .collage {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: 120px;
    grid-auto-flow: dense;
    gap: 12px;
    padding-bottom: 4rem;
  }
  @media (max-width: 900px) {
    .collage { grid-template-columns: repeat(4, 1fr); grid-auto-rows: 110px; }
  }
  @media (max-width: 560px) {
    .collage { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 140px; }
  }

  .tile {
    position: relative;
    margin: 0;
    overflow: hidden;
    border-radius: calc(var(--radius) * 0.7);
    box-shadow: var(--shadow);
    background: var(--bg-soft);
    isolation: isolate;
  }

  /* Size classes — map onto the grid. */
  .tile--small   { grid-column: span 2; grid-row: span 2; }
  .tile--square  { grid-column: span 3; grid-row: span 3; }
  .tile--wide    { grid-column: span 4; grid-row: span 2; }
  .tile--tall    { grid-column: span 2; grid-row: span 4; }

  @media (max-width: 900px) {
    .tile--small  { grid-column: span 2; grid-row: span 2; }
    .tile--square { grid-column: span 2; grid-row: span 2; }
    .tile--wide   { grid-column: span 4; grid-row: span 2; }
    .tile--tall   { grid-column: span 2; grid-row: span 3; }
  }
  @media (max-width: 560px) {
    .tile--small, .tile--square, .tile--wide, .tile--tall {
      grid-column: span 2; grid-row: span 2;
    }
  }

  .tile :global(img) {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition: filter 280ms ease, transform 500ms ease;
  }
  .tile:hover :global(img),
  .tile:focus-within :global(img) {
    filter: brightness(0.55) saturate(1.05);
    transform: scale(1.03);
  }

  /*
    Hover overlay — anchored to the bottom-right corner of each tile.
    The overlay-inner slides up + fades in, so the caption reads like
    a museum placard appearing over a dimming image.
  */
  .overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    padding: 14px;
  }
  .overlay-inner {
    max-width: 78%;
    text-align: right;
    color: #f7f3ea;
    font-size: 0.76rem;
    line-height: 1.45;
    letter-spacing: 0.01em;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.6);
    transform: translateY(8px);
    opacity: 0;
    transition: opacity 260ms ease, transform 260ms ease;
  }
  .tile:hover .overlay-inner,
  .tile:focus-within .overlay-inner {
    opacity: 1;
    transform: translateY(0);
  }

  .overlay-inner .title {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-bottom: 4px;
  }
  .overlay-inner .caption {
    margin-bottom: 6px;
    opacity: 0.92;
    max-width: 44ch;
    margin-left: auto; /* keep right-aligned even when it wraps */
  }
  .overlay-inner .meta,
  .overlay-inner .exif {
    opacity: 0.75;
    font-size: 0.7rem;
  }
  .overlay-inner .exif {
    margin-top: 2px;
    opacity: 0.6;
  }

  @media (prefers-reduced-motion: reduce) {
    .tile :global(img) { transition: filter 120ms ease; }
    .overlay-inner { transition: opacity 120ms ease; transform: none; }
  }
</style>
