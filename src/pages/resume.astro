import Nav from '../components/Nav.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const fmt = (d: string) => d; // dates are already human-formatted below

/*
  Content — transcribed from the user's PDF résumé.
  Update this file directly when the résumé changes; no CMS.
*/

