---

<Base title="resume · Afitab Iyigun">
  <div class="container">
    <Nav />

    <header class="head">
      <p class="eyebrow mono">§ 04 · résumé</p>
      <h1>{contact.name}</h1>
      <p class="lede">Math + CS at Boston University. Currently working on AI safety — interpretability, evals, and governance.</p>

      <ul class="contact mono">
        <li>{contact.location}</li>
        <li><a href={`mailto:${contact.email}`}>{contact.email}</a></li>
        <li>{contact.phone}</li>
        <li><a href={`https://${contact.linkedin}`} rel="noopener">{contact.linkedin}</a></li>
        <li><a href={`https://${contact.github}`} rel="noopener">{contact.github}</a></li>
      </ul>
    </header>

    <section class="block">
      <h2>Education</h2>
      <div class="entry">
        <div class="entry-head">
          <strong>{education.school}</strong>
          <span class="mono dim">{education.graduation}</span>
        </div>
        <div class="entry-sub">
          <span>{education.degree}</span>
          <span class="mono dim">GPA {education.gpa}</span>
        </div>
        <p class="coursework">
          <span class="kicker mono">Relevant coursework:</span>
          {education.coursework.join(', ')}.
          <span class="mono dim"> ({education.note})</span>
        </p>
      </div>
    </section>

    <section class="block">
      <h2>Experience</h2>
      {experience.map((e) => (
        <div class="entry">
          <div class="entry-head">
            <strong>{e.org}</strong>
            <span class="mono dim">{e.when}</span>
          </div>
          <div class="entry-sub">
            <em>{e.role}</em>
          </div>
          <ul>
            {e.bullets.map((b) => <li>{b}</li>)}
          </ul>
        </div>
      ))}
    </section>

    <section class="block">
      <h2>Projects</h2>
      {projects.map((p) => (
        <div class="entry">
          <div class="entry-head">
            <strong>{p.name}</strong>
            <span class="mono dim">{p.when}</span>
          </div>
          <ul>
            {p.bullets.map((b) => <li>{b}</li>)}
          </ul>
        </div>
      ))}
    </section>

    <section class="block">
      <h2>Skills</h2>
      <p class="skills">
        <span class="kicker mono">Technical:</span>
        {skills.technical.join(', ')}.
      </p>
      <p class="skills">
        <span class="kicker mono">Languages:</span>
        {skills.languages.join(', ')}.
      </p>
    </section>

    <footer class="foot mono dim">
      <span>transcribed from the PDF on file — ping me if something looks out of date</span>
    </footer>
  </div>
</Base>

<style>
  .head { padding: 3rem 0 1.5rem; }
  .eyebrow { color: var(--muted); font-size: 0.85rem; letter-spacing: 0.05em; text-transform: lowercase; margin: 0 0 1rem; }
  h1 { margin: 0 0 0.6rem; }
  .lede { color: var(--ink-soft); max-width: 62ch; margin: 0 0 1.2rem; font-size: 1.1rem; }

  .contact {
    list-style: none;
    margin: 0; padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem 1.2rem;
    font-size: 0.85rem;
    color: var(--ink-soft);
  }
  .contact li { position: relative; }
  .contact a { background: none; color: var(--ink); }
  .contact a:hover { background: none; color: var(--accent-1); }

  .block {
    padding: 2.2rem 0;
    border-top: 1px solid var(--rule);
  }
  .block h2 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 1.2rem;
  }

  .entry {
    padding: 0.6rem 0 1.4rem;
  }
  .entry-head {
    display: flex;
    gap: 1rem;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
  }
  .entry-head strong {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.02rem;
  }
  .entry-sub {
    display: flex;
    gap: 1rem;
    align-items: baseline;
    justify-content: space-between;
    margin: 0.15rem 0 0.5rem;
    color: var(--ink-soft);
    font-size: 0.95rem;
  }
  .entry-sub em {
    font-style: italic;
    color: var(--ink-soft);
  }
  .entry ul {
    margin: 0.4rem 0 0;
    padding-left: 1.1rem;
    color: var(--ink-soft);
    line-height: 1.55;
  }
  .entry ul li {
    margin: 0.25rem 0;
  }

  .coursework, .skills {
    color: var(--ink-soft);
    margin: 0.4rem 0 0;
    line-height: 1.55;
  }
  .kicker {
    color: var(--ink);
    margin-right: 0.3rem;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .foot {
    padding: 2rem 0 3rem;
    border-top: 1px solid var(--rule);
    font-size: 0.82rem;
  }

  .dim { color: var(--muted); }
  .mono { font-family: var(--font-mono); }
</style>
